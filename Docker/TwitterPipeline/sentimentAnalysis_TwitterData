output_file = open("resulting_data.csv", "w")
input_file = open("project_twitter_data.csv", "r")

punctuation_chars = ["'", '"', ",", ".", "!", ":", ";", '#', '@']
def strip_punctuation(word):
    new_word = ""
    for letter in word:
        if letter in punctuation_chars:
            letter = letter.replace(letter,"")
        new_word  = new_word + letter
    return new_word

# lists of words to use
positive_words = []
with open("positive_words.txt") as pos_f:
    for lin in pos_f:
        if lin[0] != ';' and lin[0] != '\n':
            positive_words.append(lin.strip())

negative_words = []
with open("negative_words.txt") as pos_f:
    for lin in pos_f:
        if lin[0] != ';' and lin[0] != '\n':
            negative_words.append(lin.strip())

def get_pos(sentence):
    counter=0
    words = sentence.split(" ")
    for word in words:
        #print(word)
        if strip_punctuation(word).lower() in positive_words:
            counter += 1
    return counter

def get_neg(sentence):
    counter=0
    words = sentence.split(" ")
    for word in words:
        if strip_punctuation(word) in negative_words:
            counter +=1
    return counter

